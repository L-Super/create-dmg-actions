{
  "name": "create-dmg-actions",
  "description": "GitHub Action to create macOS DMG files",
  "version": "1.1.0",
  "author": "L-Super",
  "private": true,
  "homepage": "https://github.com/L-Super/create-dmg-actions",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/L-Super/create-dmg-actions.git"
  },
  "bugs": {
    "url": "https://github.com/L-Super/create-dmg-actions/issues"
  },
  "keywords": [
    "actions",
    "dmg",
    "macos"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "package": "npx esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --sourcemap --legal-comments=linked",
    "package:watch": "npm run package -- --watch",
    "all": "npm run format:write && npm run lint && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^25.6.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.2",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.32.1"
  }
}
